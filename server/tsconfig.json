{
	"compilerOptions": {
		"target": "es2020",
		"lib": ["es2020"],
		"module": "commonjs",
		"moduleResolution": "node",
		"sourceMap": true,
		"strict": true,
		"outDir": "out",
		"rootDir": "src",
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["src"],
	"exclude": [
		"node_modules",
		".vscode-test",
		"src/server.browser.ts",
		"src/providers/index.browser.ts"
	]
}
